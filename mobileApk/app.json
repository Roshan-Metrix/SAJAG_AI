{
    "expo": {
        "name": "SAJAG AI",
        "slug": "sajagai",
        "scheme": "sajagai",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",

        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.sajag.disastermanagement",
            "googleMapsApiKey": "AIzaSyCbOF0WAgNk4szWE6wXrLmVzzz2Bxp_YNo"
        },

        "android": {
            "config": {
                "googleMaps": {
                    "apiKey": "AIzaSyCbOF0WAgNk4szWE6wXrLmVzzz2Bxp_YNo"
                }
            },
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/android-icon-foreground.png",
                "backgroundImage": "./assets/android-icon-background.png",
                "monochromeImage": "./assets/android-icon-monochrome.png"
            },
            "package": "com.sajag.disastermanagement",
            "permissions": [
                "android.permission.ACCESS_COARSE_LOCATION",
                "android.permission.ACCESS_FINE_LOCATION",
                "android.permission.RECORD_AUDIO",
                "android.permission.MODIFY_AUDIO_SETTINGS",
                "android.permission.FOREGROUND_SERVICE",
                "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
            ]
        },

        "web": {
            "favicon": "./assets/favicon.png"
        },

        "plugins": [
            "expo-router",
            "expo-status-bar",
            "expo-splash-screen",
            [
                "expo-location",
                {
                    "locationWhenInUsePermission": "Allow SAJAG AI to use your location."
                }
            ],
            "expo-audio"
        ],

        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#E6F4FE"
        },

        "extra": {
            "router": {},
            "eas": {
                "projectId": "3a05bb17-5ca7-4fb8-b24d-695b947d06a9"
            }
        }
    }
}
